{
  "name": "neondeck",
  "version": "0.2.0-beta.2",
  "description": "NEONDECK — local-first task / project / idea command center with a live animated dashboard and an agent-safe API.",
  "type": "module",
  "scripts": {
    "start": "tsx server/src/server.ts",
    "dev": "tsx watch server/src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build": "npm run build:frontend",
    "seed": "tsx server/src/seed.ts",
    "seed:force": "tsx server/src/seed.ts --force"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
