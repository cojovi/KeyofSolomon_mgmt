# Key of Solomon Beta 2 environment
# Copy this file to .env and adjust as needed.

# Port the app + API listen on
PORT=8787

# Local API token. Every /api/v1 request (except /health) must send:
#   Authorization: Bearer <LOCAL_API_TOKEN>
LOCAL_API_TOKEN=neondeck-local-token-change-me

# Scoped token used by Gordon. It is accepted only under /api/v1/agent.
GORDON_API_TOKEN=replace-with-a-different-long-random-token

# Gordon / OpenClaw webhook egress. Keep the complete URL and hook token secret.
OPENCLAW_WEBHOOK_ENABLED=false
OPENCLAW_SOLOMON_WEBHOOK_URL=
OPENCLAW_HOOK_TOKEN=

# Optional direct Chat with Gordon. The Gateway token is full owner/operator
# access: keep it server-only and expose the Gateway only on the private tailnet.
OPENCLAW_GATEWAY_CHAT_ENABLED=false
OPENCLAW_GATEWAY_BASE_URL=https://cojovis-mac-mini-1.tail8e0a20.ts.net
OPENCLAW_GATEWAY_TOKEN=

# Path to the SQLite database file (created automatically)
DATABASE_PATH=./data/neondeck.db
